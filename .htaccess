RewriteEngine On

# Serve /old_design/ as static files — skip SPA rewrite
RewriteCond %{REQUEST_URI} ^/legacy/ [NC]
RewriteRule ^ - [L]

# If file or directory exists, serve directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# All other requests → React SPA
RewriteRule . /index.html [L]
