RewriteEngine On

# Legacy SPA: subroutes that don't match a real file → serve legacy index.html
RewriteCond %{REQUEST_URI} ^/legacy/v1/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /legacy/v1/index.html [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# New React SPA fallback
RewriteRule . /index.html [L]
